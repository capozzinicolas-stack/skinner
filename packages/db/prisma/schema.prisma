generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// TENANTS (Clientes B2B)
// ============================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active, paused, deleted
  plan      String   @default("starter") // starter, growth, enterprise

  // Branding
  logoUrl       String?
  primaryColor  String   @default("#0ea5e9")
  secondaryColor String  @default("#075985")
  brandVoice    String?
  disclaimer    String?

  // Limits
  analysisLimit    Int @default(200)
  analysisUsed     Int @default(0)
  excessCostPerAnalysis Float @default(3.50)
  commissionRate   Float @default(0.03) // 3%

  // Channels
  linkEnabled   Boolean @default(true)
  qrEnabled     Boolean @default(true)
  widgetEnabled Boolean @default(false)
  tabletEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  analyses       Analysis[]
  tenantConfig   TenantConfig?
  subscriptions  Subscription[]
  usageEvents    UsageEvent[]
  kits           Kit[]
  integrations   Integration[]

  @@map("tenants")
}

model TenantConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Analysis config
  maxQuestions       Int     @default(7)
  restrictedConditions String? // JSON array of conditions to exclude
  customPromptSuffix String? // Extra instructions for Claude

  // Delivery config
  emailEnabled     Boolean @default(true)
  whatsappEnabled  Boolean @default(false)
  whatsappNumber   String?
  pdfRetentionDays Int     @default(90)

  // Integration config
  hubspotApiKey    String?
  salesforceApiKey String?
  shopifyDomain    String?
  webhookUrl       String?

  // Kit config
  kitEnabled    Boolean @default(true)
  kitDiscount   Float?  // optional percentage discount for kit purchases

  // Questionnaire visibility
  questionAllergiesEnabled    Boolean @default(true)
  questionSunscreenEnabled    Boolean @default(true)
  questionPregnantEnabled     Boolean @default(true)
  photoOnlyMode               Boolean @default(false)

  // Welcome screen
  welcomeTitle                String?
  welcomeDescription          String?
  welcomeCtaText              String?
  welcomeSubtext              String?
  welcomeSubtextVisible       Boolean @default(true)

  // Consent screen
  consentExtraText            String?
  consentButtonText           String?

  // Photo screen
  photoTitle                  String?
  photoInstruction            String?
  photoExtraText              String?

  // Results: section visibility
  resultsShowBarrier          Boolean @default(true)
  resultsShowConditions       Boolean @default(true)
  resultsShowConditionsDesc   Boolean @default(true)
  resultsShowSeverityBars     Boolean @default(true)
  resultsShowActionPlan       Boolean @default(true)
  resultsShowTimeline         Boolean @default(false)
  resultsShowAlertSigns       Boolean @default(true)
  resultsShowProducts         Boolean @default(true)
  resultsShowServices         Boolean @default(true)
  resultsShowMatchScore       Boolean @default(true)
  resultsShowPdfButton        Boolean @default(true)
  resultsShowPrices           Boolean @default(true)

  // Results: content
  resultsTopMessage           String?
  resultsFooterText           String?
  productCtaText              String?
  serviceCtaText              String?

  // Results: limits
  maxProductRecs              Int?
  maxServiceRecs              Int?

  // Storefront Lite
  storefrontEnabled       Boolean @default(false)
  whatsappMessage         String?   // custom message template
  mercadoPagoEnabled      Boolean @default(false)
  mercadoPagoEmail        String?   // email for MercadoPago payment links
  storefrontCtaMode       String  @default("external")  // "whatsapp" | "mercadopago" | "both" | "external"

  // Skin projection feature (~$0.12 per use, on-demand only)
  projectionEnabled       Boolean @default(true)

  // Admin overrides (locks prevent tenant from changing)
  adminLockedFields    String?  // JSON array of field names that tenant cannot modify
  adminNotes           String?  // Internal notes about this tenant's config

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_configs")
}

// ============================================
// USERS (Admin Skinner + Usuarios B2B)
// ============================================

model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String // hashed
  role     String @default("b2b_viewer") // skinner_admin, b2b_admin, b2b_analyst, b2b_viewer

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ============================================
// PRODUCTS (Catalogo del Tenant)
// ============================================

model Product {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sku          String
  name         String
  description  String?
  imageUrl     String?
  price        Float?
  ecommerceLink String?

  // Ingredients & classification
  activeIngredients String? // JSON array
  concernTags       String  // JSON array: ["acne", "hyperpigmentation"]
  skinTypeTags      String  // JSON array: ["oily", "combination"]
  objectiveTags     String  // JSON array: ["anti-aging", "radiance"]
  severityLevel     Int     @default(1) // 1=mild, 2=moderate, 3=severe
  stepRoutine       String? // cleanser, toner, serum, moisturizer, SPF, treatment
  useTime           String  @default("both") // am, pm, both
  contraindications String? // JSON array

  // Ranking (tenant-controlled priority for tiebreaking in recommendations)
  priorityRank      Int     @default(0) // higher = recommended first on score ties

  // Type & service fields
  type              String  @default("product") // "product" | "service"
  bookingLink       String?  // booking/scheduling link for services
  sessionCount      Int?     // recommended number of sessions
  sessionFrequency  String?  // "semanal", "quinzenal", "mensal"
  durationMinutes   Int?     // duration of each session in minutes

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recommendations Recommendation[]
  kitItems        KitItem[]

  @@unique([tenantId, sku])
  @@map("products")
}

// ============================================
// ANALYSES (Registro de cada analisis)
// ============================================

model Analysis {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Client info (optional, anonymous by default)
  clientEmail String?
  clientName  String?
  clientAge   String? // age range

  // Questionnaire answers
  questionnaireData String // JSON

  // Photo (not stored by default for LGPD)
  photoProcessed Boolean @default(true) // true = photo was processed and discarded

  // Analysis results
  status    String @default("pending") // pending, processing, completed, failed
  skinType  String? // oily, dry, combination, normal, sensitive
  conditions String? // JSON array of detected conditions
  severityScores String? // JSON: {"acne": 2, "aging": 1}
  barrierStatus  String? // healthy, compromised, needs_attention
  fitzpatrick    String? // I-VI
  primaryObjective String?

  // Raw Claude response (for debugging)
  rawResponse String?

  // Kit link (unique slug for public kit page)
  kitLink    String?  @unique

  // Timing
  latencyMs  Int?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime @default(now())

  results         AnalysisResult?
  recommendations Recommendation[]
  report          Report?

  @@map("analyses")
}

model AnalysisResult {
  id         String   @id @default(cuid())
  analysisId String   @unique
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Structured output from SAE
  summary          String // Main diagnosis text
  actionPlan       String // JSON: phases with recommendations
  timelineExpected String? // JSON: expectations at 4/8/12 weeks
  alertSigns       String? // JSON: when to see a dermatologist

  createdAt DateTime @default(now())

  @@map("analysis_results")
}

// ============================================
// RECOMMENDATIONS
// ============================================

model Recommendation {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  rank           Int // Order of recommendation
  matchScore     Float // 0-1 adherence score
  reason         String // Why this product was recommended
  howToUse       String? // Usage instructions

  // Tracking
  trackingRef    String @unique @default(cuid()) // skr_ref parameter
  clickedAt      DateTime?

  createdAt DateTime @default(now())

  conversions Conversion[]

  @@map("recommendations")
}

// ============================================
// REPORTS (PDF)
// ============================================

model Report {
  id         String   @id @default(cuid())
  analysisId String   @unique
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  pdfUrl    String?
  channel   String   @default("download") // download, email, whatsapp
  sentAt    DateTime?
  sentTo    String? // email or phone

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("reports")
}

// ============================================
// BILLING
// ============================================

model Subscription {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String?  @unique
  stripeCustomerId     String?
  plan                 String   @default("starter")
  status               String   @default("active") // active, past_due, canceled
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

model UsageEvent {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type      String // analysis, excess_analysis, commission
  quantity  Int      @default(1)
  unitPrice Float?
  total     Float?
  metadata  String? // JSON

  createdAt DateTime @default(now())

  @@map("usage_events")
}

// ============================================
// CONVERSIONS (Tracking de comisiones)
// ============================================

model Conversion {
  id               String         @id @default(cuid())
  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  type      String // click, purchase
  saleValue Float?
  commission Float?

  createdAt DateTime @default(now())

  @@map("conversions")
}

// ============================================
// MANUAL KITS
// ============================================

model Kit {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String    // "Kit Anti-Acne Verao"
  slug        String    // unique per tenant for URL
  description String?
  isActive    Boolean   @default(true)
  discount    Float?    // percentage discount for this kit

  // Conditions that trigger this kit recommendation
  targetConditions String?  // JSON array of condition names
  targetSkinTypes  String?  // JSON array of skin types

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items KitItem[]

  @@unique([tenantId, slug])
  @@map("kits")
}

model KitItem {
  id        String  @id @default(cuid())
  kitId     String
  kit       Kit     @relation(fields: [kitId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rank Int     // display order
  note String? // optional note like "Usar pela manha"

  @@map("kit_items")
}

// ============================================
// DERMATOLOGICAL KNOWLEDGE BASE
// ============================================

model SkinCondition {
  id          String @id @default(cuid())
  name        String @unique // acne, hyperpigmentation, aging, etc.
  displayName String
  description String
  category    String // inflammatory, pigmentation, aging, barrier, sensitivity

  // Treatment info
  commonIngredients String? // JSON array of effective ingredients
  avoidIngredients  String? // JSON array of ingredients to avoid
  baseRoutine       String? // JSON: default routine recommendation
  alertSigns        String? // JSON: when to see a doctor

  severity1Desc String? // Mild description
  severity2Desc String? // Moderate description
  severity3Desc String? // Severe description

  // Visual instruction sent to Gemini when generating post-treatment projection.
  // Use {intensity} as placeholder for the percentage improvement (50% at week 8, 80% at week 12).
  // Editable via /admin so new conditions added through the panel propagate automatically
  // to the projection pipeline without code changes.
  visualEditPrompt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("skin_conditions")
}

model Ingredient {
  id          String @id @default(cuid())
  name        String @unique
  displayName String
  description String?
  category    String? // retinoid, aha, bha, peptide, antioxidant, etc.

  // Effectiveness
  treatsConditions  String? // JSON array of condition names
  skinTypes         String? // JSON array of compatible skin types
  contraindications String? // JSON array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ingredients")
}

// ============================================
// PLATFORM CONFIG (Singleton — global settings)
// ============================================

model PlatformConfig {
  id                          String   @id @default("default")
  analysisGlobalRules         String?  // Custom rules appended to Claude system prompt
  analysisRestrictedConditions String? // Global conditions Claude should never mention
  projectionPromptTemplate    String?  // Custom Gemini projection prompt (overrides default)
  questionnaireConfig         String?  // JSON: StoredQuestion[] — dynamic questionnaire definition
  updatedAt                   DateTime @updatedAt

  @@map("platform_config")
}

// ============================================
// LEADS (Marketing site)
// ============================================

model Lead {
  id       String @id @default(cuid())
  name     String
  email    String
  company  String?
  segment  String? // laboratorio, clinica, farmacia, spa, outro
  message  String?
  source   String @default("website") // website, demo, landing

  createdAt DateTime @default(now())

  @@map("leads")
}

// ============================================
// INTEGRATIONS (Ecommerce platform connections)
// ============================================

model Integration {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  platform      String    // "nuvemshop" | "shopify" | etc
  storeId       String?   // external store ID
  accessToken   String?   // encrypted in production
  refreshToken  String?
  scopes        String?   // JSON array of granted scopes
  status        String    @default("pending") // pending, active, error, disconnected
  lastSyncAt    DateTime?
  metadata      String?   // JSON for platform-specific data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, platform])
  @@map("integrations")
}
