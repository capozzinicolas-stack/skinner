generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// TENANTS (Clientes B2B)
// ============================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active, pending_payment, paused, deleted
  plan      String   @default("growth") // growth, pro, enterprise (renamed Apr-2026 from starter/growth)

  // When true, the one-time setup fee is NOT charged on signup. Used by admin
  // for custom-plan tenants where the setup is waived as part of the negotiated deal.
  skipSetupFee Boolean @default(false)

  // Per-tenant override for capability flags from Plan. NULL = inherit from
  // Plan.allowIdentityLimit. Non-null = override (true/false). Used so the
  // admin /tenants/novo-custom flow can grant capabilities to custom-priced
  // tenants without polluting the public Plan rows.
  customAllowIdentityLimit Boolean?

  // Custom-plan display overrides. Both are NULL for standard signups
  // (growth/pro flow) — the UI falls back to Plan.name + Plan.monthlyPriceBRL.
  // For tenants who came in via /admin/tenants/novo-custom, the webhook
  // persists these from session metadata so /dashboard/faturamento shows
  // the negotiated label + actual price the customer pays at Stripe,
  // not the generic "enterprise" tier defaults.
  planLabel              String?
  customMonthlyPriceBRL  Float?

  // Branding
  logoUrl       String?
  primaryColor  String   @default("#0ea5e9")
  secondaryColor String  @default("#075985")
  brandVoice    String?
  disclaimer    String?

  // Limits
  analysisLimit    Int @default(200)
  analysisUsed     Int @default(0)
  excessCostPerAnalysis Float @default(3.50)
  commissionRate   Float @default(0.03) // 3%

  // Channels
  linkEnabled   Boolean @default(true)
  qrEnabled     Boolean @default(true)
  widgetEnabled Boolean @default(false)
  tabletEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  analyses       Analysis[]
  tenantConfig   TenantConfig?
  subscriptions  Subscription[]
  usageEvents    UsageEvent[]
  kits           Kit[]
  integrations   Integration[]
  channels       AnalysisChannel[]

  @@map("tenants")
}

model TenantConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Analysis config
  maxQuestions       Int     @default(7)
  restrictedConditions String? // JSON array of conditions to exclude
  customPromptSuffix String? // Extra instructions for Claude
  // Tone of the patient-facing analysis output.
  // "humanized" (default): warm, accessible language; clinical jargon translated automatically.
  // "technical": full clinical terminology — for B2B clinics that prefer medical credibility.
  analysisTone       String  @default("humanized")

  // Cross-tenant benchmark opt-in. When true, this tenant's anonymized aggregate
  // metrics (counts only — never individual records) contribute to the platform-wide
  // average AND this tenant can view the platform benchmark in their dashboard.
  // Off by default (privacy-first). Min 3 opt-in tenants required to expose any
  // benchmark to avoid de-anonymization risk.
  benchmarkOptIn     Boolean @default(false)

  // Delivery config
  emailEnabled     Boolean @default(true)
  whatsappEnabled  Boolean @default(false)
  whatsappNumber   String?
  pdfRetentionDays Int     @default(90)

  // Integration config
  hubspotApiKey    String?
  salesforceApiKey String?
  shopifyDomain    String?
  webhookUrl       String?

  // Kit config
  kitEnabled    Boolean @default(true)
  kitDiscount   Float?  // optional percentage discount for kit purchases

  // Questionnaire visibility
  questionAllergiesEnabled    Boolean @default(true)
  questionSunscreenEnabled    Boolean @default(true)
  questionPregnantEnabled     Boolean @default(true)
  photoOnlyMode               Boolean @default(false)

  // Welcome screen
  welcomeTitle                String?
  welcomeDescription          String?
  welcomeCtaText              String?
  welcomeSubtext              String?
  welcomeSubtextVisible       Boolean @default(true)

  // Consent screen
  consentExtraText            String?
  consentButtonText           String?

  // Photo screen
  photoTitle                  String?
  photoInstruction            String?
  photoExtraText              String?

  // Results: section visibility
  resultsShowBarrier          Boolean @default(true)
  resultsShowConditions       Boolean @default(true)
  resultsShowConditionsDesc   Boolean @default(true)
  resultsShowSeverityBars     Boolean @default(true)
  resultsShowActionPlan       Boolean @default(true)
  resultsShowTimeline         Boolean @default(false)
  resultsShowAlertSigns       Boolean @default(true)
  resultsShowProducts         Boolean @default(true)
  resultsShowServices         Boolean @default(true)
  resultsShowMatchScore       Boolean @default(true)
  resultsShowPdfButton        Boolean @default(true)
  resultsShowPrices           Boolean @default(true)

  // Results: content
  resultsTopMessage           String?
  resultsFooterText           String?
  productCtaText              String?
  serviceCtaText              String?

  // Results: limits
  maxProductRecs              Int?
  maxServiceRecs              Int?

  // Storefront Lite
  storefrontEnabled       Boolean @default(false)
  whatsappMessage         String?   // custom message template
  mercadoPagoEnabled      Boolean @default(false)
  mercadoPagoEmail        String?   // email for MercadoPago payment links
  storefrontCtaMode       String  @default("external")  // "whatsapp" | "mercadopago" | "both" | "external"

  // Skin projection feature (~$0.12 per use, on-demand only)
  projectionEnabled       Boolean @default(true)

  // Lead capture (between consent + questionnaire). All defaults preserve the
  // pre-feature behaviour for tenants that don't opt in:
  //   - contactCaptureEnabled = true → show the screen (but everything optional)
  //   - contactCaptureRequired = false → patient can skip without filling anything
  //   - autoSendPdfEmail = false → no auto-delivery (existing flow unchanged)
  //   - notifyTenantNewLead = false → no notification spam to b2b_admins
  contactCaptureEnabled    Boolean @default(true)
  contactCaptureRequired   Boolean @default(false)
  contactCustomMessage     String?
  autoSendPdfEmail         Boolean @default(false)
  notifyTenantNewLead      Boolean @default(false)

  // Admin overrides (locks prevent tenant from changing)
  adminLockedFields    String?  // JSON array of field names that tenant cannot modify
  adminNotes           String?  // Internal notes about this tenant's config

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_configs")
}

// ============================================
// USERS (Admin Skinner + Usuarios B2B)
// ============================================

model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String // hashed
  role     String @default("b2b_viewer") // skinner_admin, b2b_admin, b2b_analyst, b2b_viewer

  // Null = user has never rotated their password (still using temp one from
  // welcome email, or seed). Frontend shows a banner asking them to change it
  // until this is set. Updated by user.changePassword.
  passwordChangedAt DateTime?

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  resetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ============================================
// PLANS (admin-managed pricing tiers)
// ============================================
//
// Source of truth for pricing/limits/features. Replaces the hardcoded PLANS
// dictionary that previously lived in apps/web/src/lib/billing/plans.ts.
//
// Lifecycle invariants:
//   - id is the slug used in URLs, Stripe metadata, and Tenant.plan. NEVER
//     change once created (would orphan existing tenants and Stripe records).
//   - stripePriceId / stripeSetupPriceId are NEVER edited in place. When the
//     admin changes monthlyPriceBRL or setupFeeBRL, the backend creates a NEW
//     Stripe Price (Stripe prices are immutable) and rotates the FK here.
//     Existing subscriptions keep their old Stripe Price (Stripe handles that
//     transparently) so grandfathering is automatic at the Stripe layer.
//   - Limits (analysisLimit, commissionRate, maxUsers, excessCostPerAnalysis)
//     are SNAPSHOTTED to Tenant.* at signup. Changing them on the Plan does
//     NOT propagate to existing tenants unless the admin explicitly opts in
//     via the apply-to-existing checkbox in /admin/planos.
//   - features + name + ctaText are read live from this row (no snapshot), so
//     visual rewordings DO propagate to existing tenants' faturamento UI.
//   - Soft delete only (deprecated = true). Hard delete is blocked because
//     legacy tenants reference the id via Tenant.plan.
//
// See CLAUDE.md "Plans (admin-managed)" for the full contract.
model Plan {
  id                      String  @id // "growth", "pro", "enterprise", or any custom slug
  name                    String
  monthlyPriceBRL         Float   // shown in UI; gates Stripe Price creation when changed
  setupFeeBRL             Float?  // null = no setup; 0 also means none
  analysisLimit           Int
  commissionRate          Float   // 0..1 (e.g. 0.03 = 3%)
  excessCostPerAnalysis   Float   @default(0)
  maxUsers                Int
  maxChannels             Int     @default(1) // analysis_channels per tenant cap
  // Capability: when true, the tenant can configure per-channel identity
  // limits (max analyses per email/phone within a rolling window). Off by
  // default — Growth tier should not get this. Pro/Advanced plans turn it on.
  allowIdentityLimit      Boolean @default(false)
  features                String  // JSON array of bullet strings
  ctaText                 String  @default("Inscrever-se")

  stripePriceId           String? // null for enterprise / custom-allowed plans
  stripeSetupPriceId      String?

  visible                 Boolean @default(true)  // false = hidden from /planos
  deprecated              Boolean @default(false) // true = no new signups; existing tenants stay
  customAllowed           Boolean @default(false) // true = enterprise tier; price is "Sob consulta", no Stripe Price required

  displayOrder            Int     @default(0)

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("plans")
}

// One-shot tokens issued by /api/auth/forgot, consumed by /api/auth/reset.
// We store ONLY the SHA-256 hash of the token — the plain token lives only
// in the email link. 1h expiry, single-use (usedAt timestamp prevents replay).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 hex of the token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ============================================
// PRODUCTS (Catalogo del Tenant)
// ============================================

model Product {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sku          String
  name         String
  description  String?
  imageUrl     String?
  price        Float?
  ecommerceLink String?

  // Ingredients & classification
  activeIngredients String? // JSON array
  concernTags       String  // JSON array: ["acne", "hyperpigmentation"]
  skinTypeTags      String  // JSON array: ["oily", "combination"]
  objectiveTags     String  // JSON array: ["anti-aging", "radiance"]
  severityLevel     Int     @default(1) // 1=mild, 2=moderate, 3=severe
  stepRoutine       String? // cleanser, toner, serum, moisturizer, SPF, treatment
  useTime           String  @default("both") // am, pm, both
  contraindications String? // JSON array

  // Ranking (tenant-controlled priority for tiebreaking in recommendations)
  priorityRank      Int     @default(0) // higher = recommended first on score ties

  // Type & service fields
  type              String  @default("product") // "product" | "service"
  bookingLink       String?  // booking/scheduling link for services
  sessionCount      Int?     // recommended number of sessions
  sessionFrequency  String?  // "semanal", "quinzenal", "mensal"
  durationMinutes   Int?     // duration of each session in minutes

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recommendations Recommendation[]
  kitItems        KitItem[]

  @@unique([tenantId, sku])
  @@map("products")
}

// ============================================
// ANALYSES (Registro de cada analisis)
// ============================================

model Analysis {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Client info (optional, anonymous by default)
  clientEmail String?
  clientName  String?
  clientAge   String? // age range
  clientPhone String? // WhatsApp / cellphone, captured during contact step
  // LGPD opt-in: true = patient explicitly checked "concordo em receber contato"
  // and supplied at least one contact channel. Used to gate B2B outreach.
  consentToContact   Boolean   @default(false)
  contactCapturedAt  DateTime? // null = capture screen was skipped or disabled

  // Geo (auto-captured from request IP via Vercel/Cloudflare headers — LGPD-friendly:
  // city/region/country only, never the raw IP). Used by the B2B analytics dashboard
  // to slice metrics by region. All fields are optional — if headers are missing,
  // they stay null and analytics groups them as "Desconhecido".
  clientCountry String? // ISO-2 (e.g. "BR")
  clientRegion  String? // state/region (e.g. "SP", "RJ")
  clientCity    String?

  // Questionnaire answers
  questionnaireData String // JSON

  // Photo (not stored by default for LGPD)
  photoProcessed Boolean @default(true) // true = photo was processed and discarded

  // Analysis results
  status    String @default("pending") // pending, processing, completed, failed
  skinType  String? // oily, dry, combination, normal, sensitive
  conditions String? // JSON array of detected conditions
  severityScores String? // JSON: {"acne": 2, "aging": 1}
  barrierStatus  String? // healthy, compromised, needs_attention
  fitzpatrick    String? // I-VI
  primaryObjective String?

  // Raw Claude response (for debugging)
  rawResponse String?

  // Kit link (unique slug for public kit page)
  kitLink    String?  @unique

  // Timing
  latencyMs  Int?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime @default(now())

  // Optional FK to the AnalysisChannel that originated this analysis. Lets
  // dashboards group/segment by channel (campanha, unidade, embed) without
  // forking the analysis pipeline. Nullable so legacy analyses (created
  // before channels existed) keep working.
  channelId  String?
  channel    AnalysisChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  // Identity bucket used for per-channel identity limit checks. Format:
  //   "email:lowercased@trimmed.com" or "phone:onlydigits".
  // NULL for legacy analyses or when the channel doesn't enforce identity
  // limits. Indexed alongside channelId+createdAt so the count check is
  // O(log n).
  identityKey String?

  results         AnalysisResult?
  recommendations Recommendation[]
  report          Report?

  @@index([channelId, identityKey, createdAt])
  @@map("analyses")
}

// Multiple channels per tenant — different slugs that route to the same
// analysis flow but with separate analytics, expiration, and per-channel
// volume caps. Plan-gated via Plan.maxChannels (Growth=1, Pro=3, Advanced=5).
//
// Lifecycle:
//   - Every tenant has exactly one isDefault=true channel created at signup
//     (or backfilled). Its slug equals the tenant's slug for legacy URL
//     compatibility — never delete it.
//   - status: "active" → patient flow works. "paused" → flow returns 404.
//     "expired" auto-set when expiresAt < now (computed at read, not via cron).
//   - maxAnalyses caps how many analyses can be run through this channel.
//     null = unlimited within the tenant's monthly analysis quota.
//
// Slug uniqueness is GLOBAL (not per-tenant) so /analise/{slug} resolves
// directly. UI auto-suggests "{tenantSlug}-{label-slug}" to avoid collisions.
model AnalysisChannel {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug         String    @unique
  label        String
  isDefault    Boolean   @default(false)
  expiresAt    DateTime?
  maxAnalyses  Int?
  status       String    @default("active") // active | paused | expired
  // Identity-based abuse limit (Nivel 1 — see CLAUDE.md "Identity limits").
  // When identityLimit is non-null, analysis.run requires the patient to
  // supply an email or phone (used to build identityKey) and refuses runs
  // beyond identityLimit count within identityWindowDays. Plan-gated by
  // Plan.allowIdentityLimit (override-able via Tenant.customAllowIdentityLimit).
  identityLimit       Int?
  identityWindowDays  Int?
  // Per-channel UI/copy overrides serialized as JSON. When non-null, fields
  // present in this object override the same-named TenantConfig fields for
  // patients arriving via this channel slug. Whitelisted fields only — see
  // CHANNEL_OVERRIDE_FIELDS in tenant.getBySlug for the authoritative list.
  // Null or missing key → fall back to TenantConfig value (Tenant-wide default).
  overrides    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  analyses     Analysis[]

  @@index([tenantId])
  @@map("analysis_channels")
}

model AnalysisResult {
  id         String   @id @default(cuid())
  analysisId String   @unique
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Structured output from SAE
  summary          String // Main diagnosis text
  actionPlan       String // JSON: phases with recommendations
  timelineExpected String? // JSON: expectations at 4/8/12 weeks
  alertSigns       String? // JSON: when to see a dermatologist

  createdAt DateTime @default(now())

  @@map("analysis_results")
}

// ============================================
// RECOMMENDATIONS
// ============================================

model Recommendation {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  rank           Int // Order of recommendation
  matchScore     Float // 0-1 adherence score
  reason         String // Why this product was recommended
  howToUse       String? // Usage instructions

  // Tracking
  trackingRef    String @unique @default(cuid()) // skr_ref parameter
  clickedAt      DateTime?

  createdAt DateTime @default(now())

  conversions Conversion[]

  @@map("recommendations")
}

// ============================================
// REPORTS (PDF)
// ============================================

model Report {
  id         String   @id @default(cuid())
  analysisId String   @unique
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  pdfUrl    String?
  channel   String   @default("download") // download, email, whatsapp
  sentAt    DateTime?
  sentTo    String? // email or phone

  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("reports")
}

// ============================================
// BILLING
// ============================================

model Subscription {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String?  @unique
  stripeCustomerId     String?
  plan                 String   @default("starter")
  status               String   @default("active") // active, past_due, canceled
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// Tracks Stripe webhook events that we have already processed, to short-circuit
// duplicate deliveries (Stripe retries on timeout / 5xx). The unique stripeEventId
// is checked at the top of POST /api/billing/webhook before any handler runs.
// Bounded by Stripe's retry window (~3 days) so no TTL cleanup is needed today.
model WebhookEvent {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique
  type            String
  processedAt     DateTime @default(now())

  @@map("webhook_events")
}

model UsageEvent {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type      String // analysis, excess_analysis, commission
  quantity  Int      @default(1)
  unitPrice Float?
  total     Float?
  metadata  String? // JSON

  createdAt DateTime @default(now())

  @@map("usage_events")
}

// ============================================
// CONVERSIONS (Tracking de comisiones)
// ============================================

model Conversion {
  id               String         @id @default(cuid())
  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  type      String // click, purchase
  saleValue Float?
  commission Float?

  createdAt DateTime @default(now())

  @@map("conversions")
}

// ============================================
// MANUAL KITS
// ============================================

model Kit {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String    // "Kit Anti-Acne Verao"
  slug        String    // unique per tenant for URL
  description String?
  isActive    Boolean   @default(true)
  discount    Float?    // percentage discount for this kit

  // Conditions that trigger this kit recommendation
  targetConditions String?  // JSON array of condition names
  targetSkinTypes  String?  // JSON array of skin types

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items KitItem[]

  @@unique([tenantId, slug])
  @@map("kits")
}

model KitItem {
  id        String  @id @default(cuid())
  kitId     String
  kit       Kit     @relation(fields: [kitId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rank Int     // display order
  note String? // optional note like "Usar pela manha"

  @@map("kit_items")
}

// ============================================
// DERMATOLOGICAL KNOWLEDGE BASE
// ============================================

model SkinCondition {
  id          String @id @default(cuid())
  name        String @unique // acne, hyperpigmentation, aging, etc.
  displayName String
  description String
  category    String // inflammatory, pigmentation, aging, barrier, sensitivity

  // Treatment info
  commonIngredients String? // JSON array of effective ingredients
  avoidIngredients  String? // JSON array of ingredients to avoid
  baseRoutine       String? // JSON: default routine recommendation
  alertSigns        String? // JSON: when to see a doctor

  severity1Desc String? // Mild description
  severity2Desc String? // Moderate description
  severity3Desc String? // Severe description

  // Visual instruction sent to Gemini when generating post-treatment projection.
  // Use {intensity} as placeholder for the percentage improvement (50% at week 8, 80% at week 12).
  // Editable via /admin so new conditions added through the panel propagate automatically
  // to the projection pipeline without code changes.
  visualEditPrompt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("skin_conditions")
}

model Ingredient {
  id          String @id @default(cuid())
  name        String @unique
  displayName String
  description String?
  category    String? // retinoid, aha, bha, peptide, antioxidant, etc.

  // Effectiveness
  treatsConditions  String? // JSON array of condition names
  skinTypes         String? // JSON array of compatible skin types
  contraindications String? // JSON array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ingredients")
}

// ============================================
// PLATFORM CONFIG (Singleton — global settings)
// ============================================

model PlatformConfig {
  id                          String   @id @default("default")
  analysisGlobalRules         String?  // Custom rules appended to Claude system prompt
  analysisRestrictedConditions String? // Global conditions Claude should never mention
  projectionPromptTemplate    String?  // Custom Gemini projection prompt (overrides default)
  questionnaireConfig         String?  // JSON: StoredQuestion[] — dynamic questionnaire definition
  updatedAt                   DateTime @updatedAt

  @@map("platform_config")
}

// ============================================
// LEADS (Marketing site)
// ============================================

model Lead {
  id       String @id @default(cuid())
  name     String
  email    String
  company  String?
  segment  String? // laboratorio, clinica, farmacia, spa, outro
  message  String?
  source   String @default("website") // website, demo, landing

  createdAt DateTime @default(now())

  @@map("leads")
}

// ============================================
// INTEGRATIONS (Ecommerce platform connections)
// ============================================

model Integration {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  platform      String    // "nuvemshop" | "shopify" | etc
  storeId       String?   // external store ID
  storeUrl      String?   // public storefront URL (e.g. "https://lojateste.lojavirtualnuvem.com.br")
                          // Used by lib/cart/dispatch.ts to build cart deep-links.
                          // Populated at OAuth callback (Nuvemshop GET /store) or via lazy backfill.
  accessToken   String?   // encrypted in production
  refreshToken  String?
  scopes        String?   // JSON array of granted scopes
  status        String    @default("pending") // pending, active, error, disconnected
  lastSyncAt    DateTime?
  metadata      String?   // JSON for platform-specific data
  matchStats    String?   // JSON: { skinnerCount, externalCount, matchedCount, lastChecked }
                          // SKU-match snapshot between Skinner catalog and the platform.
                          // Refreshed manually from /dashboard/integracao.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, platform])
  @@map("integrations")
}
